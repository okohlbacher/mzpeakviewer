{
  "name": "mzpeakexplorer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A lightweight, browser-based explorer for mzPeak files — an OpenMS FileInfo-style summary, a hierarchical metadata browser, and a spectrum/XIC navigator. Everything runs client-side; no upload, no backend.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@zip.js/zip.js": "2.8.26",
    "apache-arrow": "21.1.0",
    "arrow-js-ffi": "0.4.3",
    "hyparquet": "^1.26.0",
    "hyparquet-compressors": "^1.1.1",
    "lucide-react": "^0.577.0",
    "mzpeakts": "file:../../vendor/mzpeakts/lib",
    "parquet-wasm": "0.7.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "uplot": "1.6.32",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "esbuild": "^0.28.0",
    "typescript": "~5.9.3",
    "vite": "8.0.16",
    "vite-plugin-top-level-await": "1.6.0",
    "vite-plugin-wasm": "3.6.0",
    "vitest": "^2.1.9"
  }
}
