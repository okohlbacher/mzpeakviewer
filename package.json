{
  "name": "mzpeakviewer",
  "private": true,
  "version": "0.0.0",
  "description": "Unified mzPeak viewer — merge of mzPeakIV (imaging) and mzPeakExplorer (general explorer).",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "echo \"(lint configured per-phase)\" && exit 0"
  },
  "devDependencies": {
    "typescript": "~5.9.2",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
