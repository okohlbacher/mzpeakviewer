{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/controls/**",
              "components/data/**",
              "components/forms/**",
              "design_handoff_mzpeakiv_ds_sync/reference/**",
              "design_handoff_mzpeakiv_redesign/design-system/**",
              "design_handoff_mzpeakiv_redesign/prototype-reference/**",
              "ds-runtime-fallback.js",
              "ui_kits/mzpeak-iv/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:IBM Plex Sans|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: IBM Plex Sans, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|mono|className|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, dot, mono, className, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|accent|info|success|warning|danger)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'accent' | 'info' | 'success' | 'warning' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|iconLeft|iconRight|block|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, iconLeft, iconRight, block, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Button> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|className|disabled|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, onChange, label, className, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='ColormapScale'] > JSXAttribute > JSXIdentifier[name!=/^(?:colormap|low|high|orientation|onStage|className|key|ref|className|style|children)$/]",
        "message": "<ColormapScale> doesn't accept that prop. Declared props: colormap, low, high, orientation, onStage, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='ColormapScale'] > JSXAttribute[name.name='colormap'] > Literal[value!=/^(?:viridis|inferno|gray|basepeak)$/]",
        "message": "<ColormapScale> colormap must be one of 'viridis' | 'inferno' | 'gray' | 'basepeak'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ColormapScale'] > JSXAttribute[name.name='orientation'] > Literal[value!=/^(?:horizontal|vertical)$/]",
        "message": "<ColormapScale> orientation must be one of 'horizontal' | 'vertical'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NumberField'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|unit|size|placeholder|width|ariaLabel|key|ref|className|style|children)$/]",
        "message": "<NumberField> doesn't accept that prop. Declared props: value, onChange, unit, size, placeholder, width, ariaLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='NumberField'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<NumberField> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|count|defaultOpen|open|onToggle|className|children|key|ref|className|style|children)$/]",
        "message": "<Panel> doesn't accept that prop. Declared props: title, count, defaultOpen, open, onToggle, className, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedControl'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|onChange|size|ariaLabel|className|key|ref|className|style|children)$/]",
        "message": "<SegmentedControl> doesn't accept that prop. Declared props: options, value, onChange, size, ariaLabel, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedControl'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<SegmentedControl> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|options|size|ariaLabel|className|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: value, onChange, options, size, ariaLabel, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Select> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|className|key|ref|className|style|children)$/]",
        "message": "<StatRow> doesn't accept that prop. Declared props: label, value, className."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
